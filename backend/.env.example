# Copy to .env and fill in.
#
# LOCAL DEV uses SQLite automatically (no setup, works offline). The default
# below is all you need locally.
DATABASE_URL="file:./dev.db"
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# --- Accounts system ---------------------------------------------------------
# Sign the JWT sessions. Set a long random value in production.
JWT_SECRET="change-me-to-a-long-random-string"

# Email (verification codes + password reset). LEAVE BLANK in dev: codes are
# logged to the server console AND returned by the API so the flow is testable
# without an email provider. Fill these to send real mail (SMTP / company server):
#   SMTP_HOST="smtp.yourprovider.com"
#   SMTP_PORT="587"
#   SMTP_SECURE="false"
#   SMTP_USER="apikey-or-username"
#   SMTP_PASS="secret"
#   SMTP_FROM="PowerLine <no-reply@powerline.com.eg>"

# --- Production (Vercel) only -------------------------------------------------
# On Vercel the datasource auto-switches to PostgreSQL (Neon) and tables are
# created on deploy. Set these as Environment Variables in the Vercel dashboard
# (NOT in this file):
#   DATABASE_URL = Neon POOLED url   (host contains "-pooler")
#   DIRECT_URL   = Neon DIRECT url   (no "-pooler")
