# Copy to .env and fill in. The app targets PostgreSQL (Neon) for both local
# dev and production. Neon gives you TWO connection strings — use the POOLED one
# for DATABASE_URL and the DIRECT (non-pooled) one for DIRECT_URL.

# Pooled connection (host contains "-pooler"). Used by the running app.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Direct connection (no "-pooler"). Used by `prisma db push` / migrations.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Local dev server port (ignored on Vercel).
PORT=4000

# Comma-separated allowed origins. Same-origin on Vercel, so this is optional.
CORS_ORIGIN="http://localhost:5173"
