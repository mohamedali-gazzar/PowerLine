# Copy to .env and fill in.
#
# LOCAL DEV uses SQLite automatically (no setup, works offline). The default
# below is all you need locally.
DATABASE_URL="file:./dev.db"
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# --- Production (Vercel) only -------------------------------------------------
# On Vercel the datasource auto-switches to PostgreSQL (Neon) and tables are
# created on deploy. Set these as Environment Variables in the Vercel dashboard
# (NOT in this file):
#   DATABASE_URL = Neon POOLED url   (host contains "-pooler")
#   DIRECT_URL   = Neon DIRECT url   (no "-pooler")
