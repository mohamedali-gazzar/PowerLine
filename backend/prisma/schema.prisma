// PowerLine data model.
// SQLite for local dev (zero-config). To move to PostgreSQL in production,
// change `provider` to "postgresql" and update DATABASE_URL — the models below
// are written to port cleanly. SQLite has no native enums, so enum-like fields
// are stored as String and validated in the API layer (Zod) instead.

generator client {
  provider      = "prisma-client-js"
  // native = local dev; rhel-openssl-3.0.x = Vercel serverless (Node 20 / AWS Lambda).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// The datasource block below is swapped automatically by scripts/db-setup.js
// (runs on `postinstall`):
//   local dev   -> sqlite (offline, prisma/dev.db)   <-- committed default
//   Vercel/prod -> postgresql (Neon)
// You normally never edit this block by hand.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A complete offer for a customer. Today it carries one RMU configuration
/// expressed in the Powerline coding system (PRAL/PSEC). LV panels and kiosks
/// will be added as sibling relations later.
model Offer {
  id          String @id @default(cuid())
  offerNumber String @unique
  // Product family: RMU | KIOSK | LV (only RMU is configurable today)
  category    String @default("RMU")
  projectName String
  customer    String
  // Lifecycle: DRAFT | SENT | WON | LOST
  status      String @default("DRAFT")

  // SLD / drawing cover fields
  salesNumber String?
  orderNumber String?

  // Offer cover-page fields (QTN / OPTY + sales contacts)
  quotationNo        String?
  opportunityNo      String?
  salesName          String?
  salesMobile        String?
  salesEmail         String?
  salesManagerName   String?
  salesManagerMobile String?
  salesManagerEmail  String?
  supportName        String?
  supportMobile      String?
  supportEmail       String?

  // Commercial (optional at this stage — technical offer is the focus)
  currency       String  @default("USD")
  usdToEgpRate   Float?
  unitPrice      Float   @default(0)
  quantity       Int     @default(1)
  discountPct    Float   @default(0)
  validityDays   Int     @default(30)
  deliveryWeeks  Int?
  paymentTerms   String?
  warrantyMonths Int?
  notes          String?

  rmu RmuConfig?

  // Accounts system: the signed-in user who created this offer, and when it was
  // "submitted" (RMU offers are generated on creation, so set on create).
  owner       User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId     String?
  submittedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// RMU configuration in the Powerline coding system, e.g. PRAL12(2+1+M).
/// The full technical content (general/electrical data + cubicle lineup) is
/// derived from this by the assembly engine — only the inputs are stored.
model RmuConfig {
  id      String @id @default(cuid())
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId String @unique

  productType    String // PRAL (air) | PSEC (SF6/GIS)
  lbsBrand       String  @default("ABB") // ABB | MURGE | SCHNEIDER | JGGY | GRL
  clientSpec     String  @default("EECH") // EECH | KAHRABA (coding-system Variable 2)
  voltageKv      Int // 12 | 24
  nalCount       Int     @default(2) // LBS without fuse (NAL)
  nalfCount      Int     @default(1) // LBS with fuse (NALF)
  hasMetering    Boolean @default(false) // adds metering cubicle (M)
  rtuType        String  @default("NONE") // NONE | TYPE1 | TYPE2
  installation   String  @default("INDOOR") // INDOOR | OUTDOOR
  busbarCurrentA Int     @default(630)
  fuseRatingA    Int? // override; null → standard for the voltage

  // Metering options (used when hasMetering)
  meteringCtPrimaryA Int? // CT primary current (X in "X/5"); null → keep "X"
  ctClass            String? // CT accuracy class, default "0.5" (0.5 / 0.5S / 0.2)
  vtCores            Int  @default(1) // VT secondary cores: 1 or 2
  vtBurdenVa         String? // VT burden, default "50-100"
  vtClass            String? // VT accuracy class, default "0.5"
  meteringWithFuse   Boolean @default(false) // VT-Type: with fuse vs without

  // Cached human-readable code for quick listing/search, e.g. "PRAL12(2+1+M)".
  configCode String
}

// ─── Accounts system ─────────────────────────────────────────────────────────

/// A registered user of the configurator. Owns LV quotations and RMU offers, and
/// carries a profile photo (base64 data URL — serverless-safe, no disk on Vercel).
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String   @default("")
  passwordHash  String
  photo         String? // base64 data URL, e.g. "data:image/png;base64,..."
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lvQtns LvQtn[]
  offers Offer[]
}

/// One-time numeric codes emailed for sign-up verification and password reset.
/// Single-use + short expiry; the controller deletes them once consumed.
model EmailCode {
  id        String   @id @default(cuid())
  email     String
  code      String // 6-digit code
  purpose   String // "signup" | "reset"
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, purpose])
}

/// A saved LV quotation owned by a user (migrated off browser localStorage). The
/// full LvState lives in `state` as a JSON string; the summary columns are sent
/// by the client on save so listing/stats need no business logic on the server.
model LvQtn {
  id          String    @id @default(cuid())
  number      String
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String
  state       String // JSON-serialized LvState
  // client-computed summary (avoids duplicating pricing logic on the server)
  projectName String    @default("")
  customer    String    @default("")
  panelsCount Int       @default(0)
  totalEgp    Float     @default(0)
  submitted   Boolean   @default(false)
  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([ownerId, number])
  @@index([ownerId])
}
